# Doxyfile for Rendering Engine documentation

# Project details
PROJECT_NAME           = "Rendering Engine"
PROJECT_BRIEF          = "Modular Graphics Rendering Engine | v0.2.8"
PROJECT_NUMBER         = "0.2.8"
OUTPUT_DIRECTORY       = ../../Build/Docs

HTML_COLORSTYLE = LIGHT

# Input
INPUT                  = ../../RenderingEngine ../../Doc
FILE_PATTERNS          = *.hpp *.h *.cpp *.c *.py  *.md *.png *.css
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */external/*

USE_MDFILE_AS_MAINPAGE = ../../Doc/getting_started.md
IMAGE_PATH = ../../Doc/Images/
PROJECT_LOGO = ../../Doc/Images/RE_Banner.png
HTML_EXTRA_STYLESHEET = ../../Doc/Style/theme.css

# Build related
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
STRIP_CODE_COMMENTS    = NO

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html

# LaTeX output (disabled by default)
GENERATE_LATEX         = NO

# Diagrams (enable if Graphviz is installed)
HAVE_DOT               = NO
DOT_IMAGE_FORMAT       = svg
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = NO
DOT_MULTI_TARGETS      = YES

# Misc
GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = NO
QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES

# License
ALIASES                += license="\\par License:\nThis file is part of a project licensed under the zlib license. See LICENSE.md."
